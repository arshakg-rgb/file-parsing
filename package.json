{
  "name": "file-parsing-pipeline-node",
  "version": "1.0.0",
  "description": "Node.js/TypeScript port of the file parsing pipeline S3 utilities",
  "type": "module",
  "main": "dist/shared/S3Utils.js",
  "types": "dist/shared/S3Utils.d.ts",
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev:job": "tsx src/services/job_service/JobServiceHandler.ts",
    "dev:ingest": "tsx src/services/ingest/IngestServiceHandler.ts",
    "dev:detect": "tsx src/services/detect_bootstrap/DetectBootstrapServiceHandler.ts",
    "dev:parse": "tsx src/services/stream_parser/StreamParserServiceHandler.ts",
    "dev:ai": "tsx src/services/ai_classifier/main.ts",
    "dev:load": "tsx src/services/load/LoadServiceHandler.ts",
    "dev:report": "tsx src/services/report/ReportServiceHandler.ts",
    "dev:retry": "tsx src/services/retry/RetryServiceHandler.ts",
    "init:db": "tsx src/scripts/init_db.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "setup:localstack": "tsx src/scripts/setup_localstack.ts",
    "setup:gcp": "tsx src/scripts/setup_gcp.ts",
    "test:local": "tsx src/scripts/local_test.ts",
    "test:upload": "tsx src/scripts/test_upload.ts",
    "test:integration": "tsx src/scripts/integration_test.ts",
    "test:perf": "tsx src/scripts/perf_test_backfill.ts",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:fix": "eslint 'src/**/*.ts' --fix"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@dsnp/parquetjs": "^1.3.0",
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/pubsub": "^5.3.1",
    "@google-cloud/storage": "^7.21.0",
    "@google/genai": "^0.9.0",
    "apache-arrow": "^17.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "jschardet": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "node-7z": "^3.0.0",
    "node-stream-zip": "^1.15.0",
    "pg": "^8.12.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/sequelize": "^4.28.20",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10"
  }
}
