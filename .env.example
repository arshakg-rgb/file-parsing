# ============================================================
# file-parsing-pipeline-node — environment example
# ============================================================

# ---- Database ----
DATABASE_URL=postgresql://postgres:password@localhost:5432/datalead_osint

# ---- Google Cloud Platform ----
GCP_PROJECT_ID=data-etl-499916
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ---- Queue Backend ----
QUEUE_BACKEND=pubsub

# ---- Queue URLs (for pubsub, use topic names; for sqs, use full URLs) ----
INGEST_QUEUE_URL=fpp-ingest
CLASSIFY_QUEUE_URL=fpp-classify
PARSE_QUEUE_URL=fpp-parse
DLQ_QUEUE_URL=fpp-line-dlq
LOAD_QUEUE_URL=fpp-load
REPORT_QUEUE_URL=fpp-report
JOB_EVENTS_QUEUE_URL=fpp-job-events

# ---- Storage ----
DATA_BUCKET=datalead-osint
DEPLOYMENT_BUCKET=datalead-osint

# ---- Firestore ----
FIRESTORE_DATABASE_ID=file-parsing-db
TEMPLATE_COLLECTION=file-parsing-templates

# ---- AI Classifier ----
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022

# ---- Health Check ----
HEALTH_CHECK_PORT=8080

# ---- Loki / Grafana ----
LOKI_HOST=https://logs-prod-021.grafana.net
LOKI_USERNAME=your_username
LOKI_PASSWORD=your_password
